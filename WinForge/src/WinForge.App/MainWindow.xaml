<Window x:Class="WinForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinForge" Icon="Assets/WinForge.ico" Height="760" Width="1180" MinHeight="680" MinWidth="1050"
        WindowStartupLocation="CenterScreen" Background="#FF0B1020">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FF0A0F1D" BorderBrush="#FF232C3B" BorderThickness="0,0,1,0">
            <Grid Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="WinForge" Foreground="{StaticResource AccentBrush}" FontSize="30" FontWeight="SemiBold" />
                    <TextBlock Text="Windows optimisation" Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,4,0,24" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel VerticalAlignment="Top">
                        <Button x:Name="DashboardButton" Style="{StaticResource NavButton}" Content="⌂  Dashboard" Click="DashboardButton_Click" />
                        <Button x:Name="OptimiseButton" Style="{StaticResource NavButton}" Content="✓  Optimise" Click="OptimiseButton_Click" />
                        <Button x:Name="GamingButton" Style="{StaticResource NavButton}" Content="◈  Gaming" Click="GamingButton_Click" />
                        <Button x:Name="AppsButton" Style="{StaticResource NavButton}" Content="▦  Apps and Startup" Click="AppsButton_Click" />
                        <Button x:Name="StorageButton" Style="{StaticResource NavButton}" Content="◫  Storage" Click="StorageButton_Click" />
                        <Button x:Name="NetworkButton" Style="{StaticResource NavButton}" Content="◎  Network" Click="NetworkButton_Click" />
                        <Button x:Name="SecurityButton" Style="{StaticResource NavButton}" Content="◇  Security" Click="SecurityButton_Click" />
                        <Button x:Name="SystemButton" Style="{StaticResource NavButton}" Content="◌  System" Click="SystemButton_Click" />
                        <Button x:Name="RepairButton" Style="{StaticResource NavButton}" Content="↻  Repair and Recovery" Click="RepairButton_Click" />
                        <Button x:Name="ProfilesButton" Style="{StaticResource NavButton}" Content="▤  Profiles" Click="ProfilesButton_Click" />
                        <Button x:Name="RestoreButton" Style="{StaticResource NavButton}" Content="↩  Restore Centre" Click="RestoreButton_Click" />
                        <Button x:Name="ToolsButton" Style="{StaticResource NavButton}" Content="✦  Tools" Click="ToolsButton_Click" />
                        <Button x:Name="LogsButton" Style="{StaticResource NavButton}" Content="≡  Logs" Click="LogsButton_Click" />
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#FF121826" BorderBrush="#FF2B3547" BorderThickness="1" CornerRadius="16" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Status" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                        <TextBlock x:Name="AdminStatusText" Text="Admin check" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,5,0,10" />
                        <CheckBox x:Name="AdvancedToolsCheckBox" Content="Show advanced tools" IsChecked="True" Foreground="{StaticResource InkBrush}" Margin="0,0,0,10" Checked="AdvancedToolsCheckBox_Changed" Unchecked="AdvancedToolsCheckBox_Changed" />
                        <Button Content="Run as administrator" Style="{StaticResource SecondaryButton}" Click="RunAsAdminButton_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#FF0B1020">
            <ContentControl x:Name="PageHost" Margin="28" />
        </Border>
    </Grid>
</Window>
