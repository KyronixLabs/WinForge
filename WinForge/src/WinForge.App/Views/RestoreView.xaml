<UserControl x:Class="WinForge.Views.RestoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="180" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Restore Centre" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Review previous optimisation runs and revert reversible changes." Style="{StaticResource PageSubtitle}" />
        </StackPanel>

        <WrapPanel Grid.Row="1" Margin="0,0,0,12">
            <Button Content="Refresh snapshots" Style="{StaticResource PrimaryButton}" Click="RefreshButton_Click" />
            <Button Content="Revert selected" Style="{StaticResource SecondaryButton}" Click="RevertSelectedButton_Click" />
            <Button Content="Revert latest" Style="{StaticResource SecondaryButton}" Click="RevertLatestButton_Click" />
            <Button Content="Open snapshots folder" Style="{StaticResource SecondaryButton}" Click="OpenFolderButton_Click" />
        </WrapPanel>

        <ListBox Grid.Row="2" x:Name="SnapshotList" Background="#FF0D1322" Foreground="{StaticResource InkBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="8" />

        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,10,0,0">
            <TextBox x:Name="OutputBox" Background="#FF0D1322" Foreground="{StaticResource InkBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="12" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" />
        </Border>
    </Grid>
</UserControl>
