<UserControl x:Class="WinForge.Views.OptimiseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="170" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="Optimise" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Review the toggles, apply selected changes, or revert the latest reversible run." Style="{StaticResource PageSubtitle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,18">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Optimise" Style="{StaticResource PrimaryButton}" Click="OptimiseButton_Click" />
                    <Button Content="Revert latest" Style="{StaticResource DangerButton}" Click="RevertButton_Click" />
                    <Button Content="Select safe profile" Style="{StaticResource SecondaryButton}" Click="SafeProfileButton_Click" />
                    <Button Content="Clear all" Style="{StaticResource SecondaryButton}" Click="ClearButton_Click" />
                </StackPanel>
                <TextBlock x:Name="SelectionText" DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="OptionsPanel" />
        </ScrollViewer>

        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,10,0,0">
            <TextBox x:Name="OutputBox" Background="#FF0D1322" Foreground="{StaticResource InkBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="12" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" />
        </Border>
    </Grid>
</UserControl>
