<UserControl x:Class="WinForge.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,22">
            <TextBlock Text="Profiles" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Choose a starting point. Every option can still be changed before applying." Style="{StaticResource PageSubtitle}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Custom profile" Foreground="{StaticResource AccentBrush}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Save the current toggle selection or load a saved profile." Foreground="{StaticResource MutedBrush}" Margin="0,6,0,12" />
                        <WrapPanel>
                            <TextBox x:Name="ProfileNameBox" Width="220" Background="#FF0D1322" Foreground="{StaticResource InkBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="10" Margin="0,0,10,10" Text="My profile" />
                            <Button Content="Save current selection" Style="{StaticResource SecondaryButton}" Click="SaveProfileButton_Click" />
                            <ComboBox x:Name="SavedProfilesBox" Width="220" Background="#FF0D1322" Foreground="{StaticResource InkBrush}" Margin="0,0,10,10" />
                            <Button Content="Load saved profile" Style="{StaticResource SecondaryButton}" Click="LoadProfileButton_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <WrapPanel x:Name="ProfilesPanel" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
