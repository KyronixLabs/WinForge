<UserControl x:Class="WinForge.Views.GamingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="210" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Gaming" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Apply a reversible Maximum FPS preset, prepare a selected game and run temporary gaming sessions." Style="{StaticResource PageSubtitle}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Text="Maximum FPS Mode" Foreground="{StaticResource AccentBrush}" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="Applies safe gaming focused changes, saves the previous state and can revert the saved settings later." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,8,0,14" />
                        <WrapPanel>
                            <Button Content="Apply Gaming Optimisation" Style="{StaticResource PrimaryButton}" Click="ApplyGamingButton_Click" />
                            <Button Content="Revert Gaming Optimisation" Style="{StaticResource DangerButton}" Click="RevertGamingButton_Click" />
                            <Button Content="Generate Gaming Report" Style="{StaticResource SecondaryButton}" Click="ReportButton_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <WrapPanel>
                    <Border Style="{StaticResource Card}" Width="390">
                        <StackPanel>
                            <TextBlock Text="Core optimisations" Foreground="{StaticResource AccentBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                            <CheckBox x:Name="GameModeBox" Content="Enable Game Mode" IsChecked="True" Foreground="{StaticResource InkBrush}" Margin="0,5" />
                            <CheckBox x:Name="PowerBox" Content="Use Best Performance power mode" IsChecked="True" Foreground="{StaticResource InkBrush}" Margin="0,5" />
                            <CheckBox x:Name="CaptureBox" Content="Disable background recording and Game DVR" IsChecked="True" Foreground="{StaticResource InkBrush}" Margin="0,5" />
                            <CheckBox x:Name="NetworkPowerBox" Content="Disable network adapter power saving" IsChecked="True" Foreground="{StaticResource InkBrush}" Margin="0,5" />
                            <CheckBox x:Name="UsbPcieBox" Content="Disable USB and PCIe power saving" IsChecked="True" Foreground="{StaticResource InkBrush}" Margin="0,5" />
                            <CheckBox x:Name="MouseBox" Content="Disable mouse acceleration" IsChecked="True" Foreground="{StaticResource InkBrush}" Margin="0,5" />
                            <CheckBox x:Name="DnsFlushBox" Content="Flush DNS cache" IsChecked="True" Foreground="{StaticResource InkBrush}" Margin="0,5" />
                            <CheckBox x:Name="ShaderCacheBox" Content="Clear DirectX and GPU shader caches" IsChecked="True" Foreground="{StaticResource InkBrush}" Margin="0,5" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Width="390">
                        <StackPanel>
                            <TextBlock Text="Optional settings" Foreground="{StaticResource AccentBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                            <CheckBox x:Name="XboxGameBarBox" Content="Reduce Xbox Game Bar overlay" Foreground="{StaticResource InkBrush}" Margin="0,5" />
                            <CheckBox x:Name="HagsBox" Content="Enable Hardware Accelerated GPU Scheduling" Foreground="{StaticResource InkBrush}" Margin="0,5" />
                            <CheckBox x:Name="VisualEffectsBox" Content="Prefer performance visual effects" Foreground="{StaticResource InkBrush}" Margin="0,5" />
                            <CheckBox x:Name="GamingDnsBox" Content="Add gaming DNS note to the report" Foreground="{StaticResource InkBrush}" Margin="0,5" />
                            <CheckBox x:Name="CloseAppsBox" Content="Close selected background apps" Foreground="{StaticResource InkBrush}" Margin="0,5" />
                            <TextBlock Text="Background app process names, separated by commas" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,6" />
                            <TextBox x:Name="BackgroundAppsBox" Background="#FF0D1322" Foreground="{StaticResource InkBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="10" Text="OneDrive, Teams, Spotify" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Text="Selected game" Foreground="{StaticResource AccentBrush}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Choose a game executable and set it to use the high performance GPU where Windows supports per app graphics preferences." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,8,0,12" />
                        <DockPanel LastChildFill="True">
                            <Button Content="Choose game exe" Style="{StaticResource SecondaryButton}" Click="ChooseGameButton_Click" DockPanel.Dock="Left" />
                            <Button Content="Set high performance GPU" Style="{StaticResource PrimaryButton}" Click="SetGpuButton_Click" DockPanel.Dock="Right" />
                            <TextBox x:Name="GamePathBox" Background="#FF0D1322" Foreground="{StaticResource InkBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="10" Margin="0,0,10,10" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Text="Gaming Session Mode" Foreground="{StaticResource AccentBrush}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Session mode applies temporary performance settings and restores the previous power plan when the session ends." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,8,0,12" />
                        <WrapPanel>
                            <Button Content="Start Gaming Session" Style="{StaticResource PrimaryButton}" Click="StartSessionButton_Click" />
                            <Button Content="End Gaming Session" Style="{StaticResource DangerButton}" Click="EndSessionButton_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,10,0,0">
            <TextBox x:Name="OutputBox" Background="#FF0D1322" Foreground="{StaticResource InkBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="12" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" />
        </Border>
    </Grid>
</UserControl>
